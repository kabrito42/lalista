{
  "name": "lalista",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:system": "echo 'No system tests configured yet.' && exit 0",
    "test:e2e": "echo 'No E2E tests configured yet.' && exit 0",
    "test:ci": "npm run test:unit && npm run test:system && npm run test:e2e",
    "gen:types": "npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.3.1",
    "vitest": "^4.1.3"
  }
}
